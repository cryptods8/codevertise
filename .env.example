# Marketplace
PORT=4021
DB_PATH=codevertise.db

# Payments: "mock" (offline dev) or "x402" (real USDC over HTTP 402).
# Guards: mock + PAYOUT_PRIVATE_KEY refuses to boot (mock funding is free);
#         mock + NODE_ENV=production requires ALLOW_MOCK_PAYMENTS=1.
PAYMENTS_MODE=mock
# CAIP-2 network: eip155:84532 = Base Sepolia, eip155:8453 = Base mainnet
X402_NETWORK=eip155:84532
# Treasury address receiving advertiser deposits (REQUIRED in x402 mode)
PAY_TO_ADDRESS=0x0000000000000000000000000000000000000000
FACILITATOR_URL=https://facilitator.x402.org

# Public origin the app is served from (no trailing slash). Used to build the
# absolute URLs in the Farcaster Mini App manifest (/.well-known/farcaster.json)
# and the Terms/Privacy links embedded in the SIWE sign-in message.
# PUBLIC_URL=https://codevertise.dev
# Version identifier of the Terms of Service currently in effect. Embedded in the
# SIWE message so each advertiser signs agreement to a specific version, recorded
# per-account, and exposed at /v1/info.legal. Bump this whenever the Terms change.
# LEGAL_VERSION=2026-06-13.6
# Farcaster domain ownership proof for the manifest's accountAssociation, as a
# JSON object {"header":"...","payload":"...","signature":"..."} generated by
# the Farcaster Mini App manifest tool for PUBLIC_URL's domain. Omitted from the
# manifest when unset (the Mini App still loads; the domain just won't verify).
# FARCASTER_ACCOUNT_ASSOCIATION=

# Optional: treasury key for automatic on-chain publisher payouts (USDC transfer).
# Payouts wait for the tx receipt; ambiguous outcomes are never auto-refunded.
# PAYOUT_PRIVATE_KEY=0x...

# Operator token for /v1/admin/* (campaign kill switch, payout retry/reconcile).
# Admin surface is disabled (404) when unset.
# ADMIN_TOKEN=

# Set ONLY when behind a reverse proxy you control: "true", a hop count, or an
# Express trust-proxy expression. Off by default so X-Forwarded-For can't be
# spoofed to dodge per-IP rate limits.
# TRUST_PROXY=1

# Anti-fraud knobs (defaults shown)
# EVENT_SIGNING_SECRET=          # HMAC key for serve tokens; DB-persisted random key if unset
# SLOT_SECONDS=5                 # view threshold per impression
# TOKEN_TTL_SECONDS=900          # serve-token redemption window
# SERVE_RATE_PER_SEC=4
# SERVE_BURST=40
# EVENT_RATE_PER_SEC=4
# EVENT_BURST=40
# CLICK_RATIO=0.05               # max clicks per impression per (publisher, campaign)
# PUBLISHER_SHARE=0.4
